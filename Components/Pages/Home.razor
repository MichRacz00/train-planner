@page "/"
@rendermode InteractiveServer
@using train_planner.Models
@using train_planner.Services
@inject IPlkTripService TripService

<PageTitle>Train Planner</PageTitle>

<div class="tp-hero">
    <div class="tp-hero-content">
        <h1 class="tp-hero-title">Find your train trip</h1>
        <p class="tp-hero-subtitle">Search and book train tickets across the country</p>
    </div>
</div>

<div class="tp-search-wrapper">
    <div class="tp-search-card">
        <div class="tp-search-row">

            <div class="tp-search-field">
                <label class="tp-label" for="from-station">
                    <span class="tp-label-icon">&#x1F4CD;</span> From
                </label>
                <select id="from-station" class="tp-select" @bind="SearchParams.FromStation">
                    <option value="">Select departure station</option>
                    @foreach (var station in AllStations)
                    {
                        <option value="@station.Code">@station.Name</option>
                    }
                </select>
            </div>

            <button class="tp-swap-btn" @onclick="SwapStations" title="Swap stations">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M7 16V4m0 0L3 8m4-4l4 4"/>
                    <path d="M17 8v12m0 0l4-4m-4 4l-4-4"/>
                </svg>
            </button>

            <div class="tp-search-field">
                <label class="tp-label" for="to-station">
                    <span class="tp-label-icon">&#x1F3AF;</span> To
                </label>
                <select id="to-station" class="tp-select" @bind="SearchParams.ToStation">
                    <option value="">Select arrival station</option>
                    @foreach (var station in AllStations)
                    {
                        <option value="@station.Code">@station.Name</option>
                    }
                </select>
            </div>

            <div class="tp-search-field tp-search-field--narrow">
                <label class="tp-label" for="travel-date">
                    <span class="tp-label-icon">&#x1F4C5;</span> Date
                </label>
                <input id="travel-date" type="date" class="tp-input"
                       value="@SearchParams.TravelDate.ToString("yyyy-MM-dd")"
                       @onchange="OnDateChanged"
                       min="@DateTime.Today.ToString("yyyy-MM-dd")" />
            </div>

            <div class="tp-search-field tp-search-field--xnarrow">
                <label class="tp-label" for="passengers">
                    <span class="tp-label-icon">&#x1F464;</span> Passengers
                </label>
                <input id="passengers" type="number" class="tp-input" min="1" max="9"
                       @bind="SearchParams.Passengers" />
            </div>

            <button class="tp-search-btn" @onclick="SearchTrips" disabled="@IsSearching">
                @if (IsSearching)
                {
                    <span class="tp-spinner"></span>
                    <span>Searching...</span>
                }
                else
                {
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="tp-search-icon">
                        <circle cx="11" cy="11" r="8"/>
                        <line x1="21" y1="21" x2="16.65" y2="16.65"/>
                    </svg>
                    <span>Search trips</span>
                }
            </button>
        </div>

        @if (!string.IsNullOrEmpty(ValidationMessage))
        {
            <div class="tp-validation">@ValidationMessage</div>
        }
    </div>
</div>

@if (HasSearched)
{
    <div class="tp-results-wrapper">
        @if (TripResults.Count == 0)
        {
            <div class="tp-no-results">
                <div class="tp-no-results-icon">🚂</div>
                <h3>No trips found</h3>
                <p>Try adjusting your search criteria.</p>
            </div>
        }
        else
        {
            <div class="tp-results-header">
                <div class="tp-results-summary">
                    <span class="tp-results-route">
                        @GetStationName(SearchParams.FromStation) &rarr; @GetStationName(SearchParams.ToStation)
                    </span>
                    <div class="tp-results-meta-row">
                        <span class="tp-results-meta">
                            @SearchParams.TravelDate.ToString("dddd, d MMMM yyyy") &bull;
                            @SearchParams.Passengers passenger@(SearchParams.Passengers > 1 ? "s" : "")
                        </span>
                        <span class="tp-results-count">@TripResults.Count trip@(TripResults.Count != 1 ? "s" : "") found</span>
                    </div>
                </div>
            </div>

            <div class="tp-results-list">
                @foreach (var trip in TripResults)
                {
                    <div class="tp-trip-card">
                        <div class="tp-card-content">
                            <div class="tp-trip-header">
                                <div class="tp-trip-times">
                                    <span class="tp-time-value">@trip.Departure.ToString("HH:mm")</span>
                                    <span class="tp-arrow">&#8594;</span>
                                    <span class="tp-time-value">@trip.Arrival.ToString("HH:mm")</span>
                                </div>

                                <div class="tp-trip-price">
                                    <div class="tp-price-block">
                                        <span class="tp-price-amount">@((trip.PricePerPerson * SearchParams.Passengers).ToString("C0", new System.Globalization.CultureInfo("da-DK")))</span>
                                        @if (SearchParams.Passengers > 1)
                                        {
                                            <span class="tp-price-per-person">@trip.PricePerPerson.ToString("C0", new System.Globalization.CultureInfo("da-DK")) / person</span>
                                        }
                                    </div>
                                    <button class="tp-book-btn" @onclick="() => SelectTrip(trip)">
                                        Select
                                    </button>
                                </div>
                            </div>

                            <div class="tp-trip-segments">
                                @for (int i = 0; i < trip.Segments.Count; i++)
                                {
                                    var seg = trip.Segments[i];
                                    <span class="tp-segment">
                                        @GetTrainTypeLabel(seg.TrainType) P@(seg.Platform)
                                    </span>
                                    @if (i < trip.Segments.Count - 1)
                                    {
                                        <span class="tp-segment-plus">+</span>
                                    }
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
}

@if (SelectedTrip != null)
{
    <div class="tp-modal-backdrop" @onclick="CloseModal">
        <div class="tp-modal" @onclick:stopPropagation="true">
            <button class="tp-modal-close" @onclick="CloseModal">&times;</button>
            <h2 class="tp-modal-title">Booking Confirmation</h2>
            <div class="tp-modal-body">
                <div class="tp-confirmation-row">
                    <span class="tp-confirmation-label">Route</span>
                    <span class="tp-confirmation-value">@SelectedTrip.From.Name &rarr; @SelectedTrip.To.Name</span>
                </div>
                <div class="tp-confirmation-row">
                    <span class="tp-confirmation-label">Train(s)</span>
                    <span class="tp-confirmation-value">@string.Join(" + ", SelectedTrip.Segments.Select(s => $"{GetTrainTypeLabel(s.TrainType)} {s.TrainNumber}"))</span>
                </div>
                <div class="tp-confirmation-row">
                    <span class="tp-confirmation-label">Date</span>
                    <span class="tp-confirmation-value">@SearchParams.TravelDate.ToString("dddd, d MMMM yyyy")</span>
                </div>
                <div class="tp-confirmation-row">
                    <span class="tp-confirmation-label">Departure</span>
                    <span class="tp-confirmation-value">@SelectedTrip.Departure.ToString("HH:mm")</span>
                </div>
                <div class="tp-confirmation-row">
                    <span class="tp-confirmation-label">Arrival</span>
                    <span class="tp-confirmation-value">@SelectedTrip.Arrival.ToString("HH:mm")</span>
                </div>
                <div class="tp-confirmation-row">
                    <span class="tp-confirmation-label">Passengers</span>
                    <span class="tp-confirmation-value">@SearchParams.Passengers</span>
                </div>
                <div class="tp-confirmation-row tp-confirmation-row--total">
                    <span class="tp-confirmation-label">Total</span>
                    <span class="tp-confirmation-value tp-price-total">@((SelectedTrip.PricePerPerson * SearchParams.Passengers).ToString("C0", new System.Globalization.CultureInfo("da-DK")))</span>
                </div>
            </div>
            <div class="tp-modal-actions">
                <button class="tp-btn-secondary" @onclick="CloseModal">Cancel</button>
                <button class="tp-btn-primary" @onclick="ConfirmBooking">Confirm Booking</button>
            </div>
        </div>
    </div>
}

@code {
    // Shim: satisfies all existing markup bindings (FromStation, ToStation,
    // Passengers, TravelDate) without any markup changes.
    private class SearchState
    {
        public string   FromStation { get; set; } = "33605";  // Warszawa Centralna
        public string   ToStation   { get; set; } = "80416";  // Kraków Główny
        public DateOnly TravelDate  { get; set; } = DateOnly.FromDateTime(DateTime.Today);
        public int      Passengers  { get; set; } = 1;        // UI only; not sent to API

        public int FromStationId => int.TryParse(FromStation, out var v) ? v : 0;
        public int ToStationId   => int.TryParse(ToStation,   out var v) ? v : 0;
    }

    private SearchState SearchParams { get; set; } = new();

    private IReadOnlyList<PlkStation>  AllStations       { get; set; } = [];
    private List<ScheduledTrip>        TripResults       { get; set; } = [];
    private bool                       HasSearched       { get; set; } = false;
    private bool                       IsSearching       { get; set; } = false;
    private string?                    ValidationMessage { get; set; }
    private ScheduledTrip?             SelectedTrip      { get; set; }

    protected override async Task OnInitializedAsync()
    {
        AllStations = await TripService.GetStationsAsync();
    }

    private async Task SearchTrips()
    {
        ValidationMessage = null;

        if (SearchParams.FromStationId == 0)
        {
            ValidationMessage = "Please select a departure station.";
            return;
        }
        if (SearchParams.ToStationId == 0)
        {
            ValidationMessage = "Please select an arrival station.";
            return;
        }
        if (SearchParams.FromStationId == SearchParams.ToStationId)
        {
            ValidationMessage = "Departure and arrival stations must be different.";
            return;
        }

        IsSearching = true;
        TripResults = await TripService.SearchTripsAsync(new PlkTripSearchParams
        {
            FromStationId = SearchParams.FromStationId,
            ToStationId   = SearchParams.ToStationId,
            TravelDate    = SearchParams.TravelDate,
        });
        HasSearched = true;
        IsSearching = false;
    }

    private void SwapStations()
    {
        (SearchParams.FromStation, SearchParams.ToStation) =
            (SearchParams.ToStation, SearchParams.FromStation);
    }

    private void OnDateChanged(ChangeEventArgs e)
    {
        if (DateOnly.TryParse(e.Value?.ToString(), out var date))
            SearchParams.TravelDate = date;
    }

    private string GetStationName(string code)
        => AllStations.FirstOrDefault(s => s.Code == code)?.Name ?? code;

    private static string GetTrainTypeLabel(TrainType type) => type switch
    {
        TrainType.HighSpeed => "High Speed",
        TrainType.InterCity => "InterCity",
        TrainType.Regional  => "Regional",
        TrainType.Night     => "Night Train",
        _                   => type.ToString()
    };

    private static string GetAmenityIcon(string amenity) => amenity switch
    {
        "WiFi"          => "📶",
        "Bistro"        => "🍽️",
        "Power outlets" => "🔌",
        "First class"   => "⭐",
        "Quiet zone"    => "🤫",
        _               => "•"
    };

    private void SelectTrip(ScheduledTrip trip) { SelectedTrip = trip; }
    private void CloseModal()                   { SelectedTrip = null; }
    private void ConfirmBooking()
    {
        SelectedTrip      = null;
        HasSearched       = false;
        TripResults       = [];
        ValidationMessage = null;
    }
}
